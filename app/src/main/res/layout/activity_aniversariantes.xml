<?xml version="1.0" encoding="utf-8"?>
<!--
    Tela de Aniversariantes (apenas admin).
    Tem 3 botões de filtro (semana, mês, ano) que disparam a busca
    no BancoDeDados. Os resultados são adicionados dinamicamente
    no LinearLayout "listaAniversariantes" via código Java.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bege"
    android:orientation="vertical"
    tools:context=".AniversariantesActivity">

    <!-- Cabeçalho -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/azulPetroleo"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/botaoVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:minWidth="40dp"
            android:text="&lt;"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingEnd="40dp"
            android:text="Aniversariantes"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Subtítulo explicativo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Escolha um filtro para ver quem está fazendo aniversário."
        android:textColor="@color/cinzaTexto"
        android:textSize="14sp" />

    <!-- Botões de filtro lado a lado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/botaoFiltroSemana"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/botao_arredondado"
            android:text="Semana"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/botaoFiltroMes"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/botao_arredondado"
            android:text="Mês"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/botaoFiltroAno"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/botao_arredondado"
            android:text="Ano"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Mostra qual filtro está ativo -->
    <TextView
        android:id="@+id/txtFiltroAtivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Filtro: nenhum selecionado"
        android:textColor="@color/marrom"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Lista dos aniversariantes (com rolagem) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/listaAniversariantes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Os cards são adicionados pelo código Java -->

        </LinearLayout>
    </ScrollView>
</LinearLayout>
