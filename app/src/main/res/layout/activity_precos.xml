<?xml version="1.0" encoding="utf-8"?>
<!--
    Tela de Preços.
    Lista 3 modalidades de sessão, cada uma num card separado,
    com nome, descrição, duração e valor.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bege"
    android:fillViewport="true"
    tools:context=".PrecosActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Cabeçalho -->
        <LinearLayout
            android:id="@+id/cabecalho"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/azulPetroleo"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <Button
                android:id="@+id/botaoVoltar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:minWidth="40dp"
                android:text="&lt;"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingEnd="40dp"
                android:text="Tabela de Preços"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/txtSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:text="Confira nossas modalidades de atendimento"
            android:textColor="@color/cinzaTexto"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cabecalho" />

        <!-- ===== CARD 1: Sessão Completa ===== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardSessao1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_fundo"
            android:padding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSubtitulo">

            <TextView
                android:id="@+id/nome1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Sessão Completa"
                android:textColor="@color/azulPetroleo"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/preco1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/preco1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 280"
                android:textColor="@color/coral"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/desc1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Atendimento completo de RPG envolvendo o corpo inteiro. Indicado para postura, dores crônicas e reabilitação geral."
                android:textColor="@color/cinzaTexto"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nome1" />

            <TextView
                android:id="@+id/duracao1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Duração: 60 min"
                android:textColor="@color/marrom"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/desc1" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ===== CARD 2: Sessão Costas ===== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardSessao2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_fundo"
            android:padding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardSessao1">

            <TextView
                android:id="@+id/nome2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Sessão Costas"
                android:textColor="@color/azulPetroleo"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/preco2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/preco2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 180"
                android:textColor="@color/coral"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/desc2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Atendimento focado em coluna e costas. Indicado para quem sente dores cervicais ou lombares pontuais."
                android:textColor="@color/cinzaTexto"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nome2" />

            <TextView
                android:id="@+id/duracao2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Duração: 40 min"
                android:textColor="@color/marrom"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/desc2" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ===== CARD 3: Liberação Miofascial ===== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardSessao3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/card_fundo"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardSessao2">

            <TextView
                android:id="@+id/nome3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Liberação Miofascial"
                android:textColor="@color/azulPetroleo"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/preco3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/preco3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 220"
                android:textColor="@color/coral"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/desc3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Massagem terapêutica que trabalha as fáscias musculares para aliviar tensões e melhorar a mobilidade."
                android:textColor="@color/cinzaTexto"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nome3" />

            <TextView
                android:id="@+id/duracao3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Duração: 50 min"
                android:textColor="@color/marrom"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/desc3" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
